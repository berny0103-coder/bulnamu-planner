{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/r/:code", "destination": "/r.html?ref=:code" },
    { "source": "/done", "destination": "/done.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/event", "destination": "/r.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
